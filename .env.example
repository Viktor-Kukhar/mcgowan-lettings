# Supabase (database + auth + storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (transactional email — contact form notifications)
RESEND_API_KEY=your-resend-api-key

# Cron endpoint secret (used by Vercel Cron to authorise scheduled jobs)
CRON_SECRET=generate-a-strong-random-hex-string

# Unsplash (stock photo picker in blog editor — optional)
UNSPLASH_ACCESS_KEY=your-unsplash-access-key
